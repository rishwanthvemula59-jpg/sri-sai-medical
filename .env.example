# Sri Sai Medical Centre - Environment Configuration

# ========== FIREBASE CONFIG ==========
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ========== OPENAI API ==========
VITE_OPENAI_API_KEY=sk_test_your_openai_key

# ========== GOOGLE MAPS & SERVICES ==========
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_apikey
VITE_GOOGLE_TTS_API_KEY=your_google_tts_api_key

# ========== APP CONFIG ==========
VITE_APP_NAME=Sri Sai Medical Centre
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api

# ========== BACKEND SERVER ==========
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ========== FIREBASE ADMIN SDK (Backend) ==========
FIREBASE_ADMIN_SDK_KEY=path/to/serviceAccountKey.json

# ========== CHAT & AI ==========
OPENAI_API_KEY=sk_test_your_openai_key
CHAT_RATE_LIMIT_REQUESTS=10
CHAT_RATE_LIMIT_WINDOW_MS=60000

# ========== EMAIL (For contact form) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@srisaimedical.com
